# Server Config
PORT=5000
NODE_ENV=development
BACKEND_URL=http://localhost:5000
FRONTEND_URL=http://localhost:5173

# Database Config (MongoDB)
MONGODB_URI=mongodb://127.0.0.1:27017/bhatkarbase

# Auth Config
JWT_SECRET=supersecretscentoraauthkeychangeinproduction
JWT_EXPIRES_IN=7d

# Razorpay Config (Leave blank for Mock mode)
RAZORPAY_KEY_ID=
RAZORPAY_KEY_SECRET=
RAZORPAY_WEBHOOK_SECRET=

# Cloudinary Config (Leave blank for Local Storage fallback uploads)
CLOUDINARY_CLOUD_NAME=
CLOUDINARY_API_KEY=
CLOUDINARY_API_SECRET=

# Email SMTP Config (Nodemailer)
EMAIL_HOST=smtp.mailtrap.io
EMAIL_PORT=2525
EMAIL_USER=
EMAIL_PASS=
EMAIL_FROM=noreply@bhatkar-perfumes.com
